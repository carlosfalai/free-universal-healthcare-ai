# Telegram bot token from @BotFather
INSTANTHPI_BOT_TOKEN=

# Model API key (reference implementation: DeepSeek; any OpenAI-compatible API works)
DEEPSEEK_API_KEY=

# Your own Telegram numeric user id (admin commands)
ADMIN_USER_ID=

# Optional: key protecting the admin HTTP endpoints
ADMIN_API_KEY=

# Optional: key for the web API mode
WEB_API_KEY=

# Optional: run web API only, no Telegram polling
# WEB_ONLY=1

# Optional: HTTP port (default in bot.js)
# PORT=3000
